{
  "name": "@comfortcss/reset",
  "version": "1.0.0",
  "main": "dist/reset.min.css",
  "style": "dist/reset.min.css",
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/comfortcss/reset.git"
  },
  "scripts": {
    "build": "npx lightningcss --minify --bundle src/index.css -o dist/reset.min.css",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "css",
    "reset",
    "normalize",
    "modern",
    "accessible",
    "lightweight"
  ],
  "author": "ComfortCSS",
  "license": "MIT",
  "devDependencies": {
    "lightningcss": "^1.32.0",
    "lightningcss-cli": "^1.32.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "default": "./dist/reset.min.css"
    },
    "./modules": {
      "default": "./src/"
    },
    "./reset": {
      "default": "./dist/reset.min.css"
    },
    "./dist/reset.min.css": {
      "default": "./dist/reset.min.css"
    },
    "./package.json": "./package.json"
  }
}
